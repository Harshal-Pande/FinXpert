# Database (required for Prisma)
DATABASE_URL="postgresql://finxpert:finxpert@localhost:5432/finxpert"
# Schema sync (pick one):
#   npx prisma migrate dev          — dev, creates/applies migrations
#   npx prisma migrate deploy       — production
#   npm run db:push                 — dev only: push schema without migration files (fixes “table missing” quickly)
# If Prisma reports drift: npm run db:reset  (wipes local DB) or resolve migrations manually

# Server
PORT=3001

# Public URL of the Next.js app (Vercel). Used for CORS and the API root page.
# FRONTEND_URL=https://your-app.vercel.app
# Optional: comma-separated extra allowed browser origins (CORS).
# CORS_ORIGINS=https://preview-xyz.vercel.app

# JWT
JWT_SECRET="finxpert-jwt-secret-change-in-production"
JWT_EXPIRES_IN="7d"

# Market indices (Nifty, Sensex, gold): live via Yahoo Finance chart API when true (default). No OAuth keys required.
# Set false to use demo numbers only.
# MARKET_USE_YAHOO=false
#
# Yahoo Developer “Consumer Key / Secret” (OAuth) are NOT used by the chart endpoint in this app.
# Do not commit real keys; rotate any key that was ever pasted into chat or a repo.
# YAHOO_CONSUMER_KEY=
# YAHOO_CONSUMER_SECRET=

# Optional: External APIs (leave empty to disable features)
# ALPHA_VANTAGE_API_KEY=
# BINANCE_API_URL=https://api.binance.com
# NEWS_API_KEY=
# Optional second NewsAPI key (for rotation or comparison): NEWS_API_KEY_2
# NEWS_MARKET_QUERY=Indian stock market
# GEMINI_API_KEY=
