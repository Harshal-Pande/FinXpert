generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Advisor {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  created_at DateTime @default(now())
  clients   Client[]
  todos     TodoItem[]
  health_score_formula HealthScoreFormula?
  complianceObligations ComplianceObligation[]
}

model Client {
  id                 String   @id @default(uuid())
  advisor_id         String
  name               String
  age                Int
  occupation         String
  annual_income      Float
  monthly_expense    Float
  emergency_fund     Float?
  insurance_coverage Float?
  risk_profile       String?
  investment_horizon String?
  /// Sum of investment total_value; kept in sync by AssetsService.
  total_aum          Float    @default(0)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  advisor           Advisor  @relation(fields: [advisor_id], references: [id], onDelete: Cascade)
  investments       Investment[]
  healthScores      HealthScore[]
  portfolioTarget   PortfolioTarget?
  todos             TodoItem[]
  portfolioSnapshots PortfolioSnapshot[]
}

enum InvestmentType {
  Stock
  Crypto
  Debt
  Mutual_Fund
}

enum InvestmentCategory {
  STOCK
  MUTUAL_FUND
  CRYPTO
  CASH
  GOLD
}

model Investment {
  id           String   @id @default(uuid())
  client_id    String
  investment_type InvestmentType
  category     InvestmentCategory @default(STOCK)
  instrument_name String
  quantity     Float
  avg_buy_price Float @default(0)
  current_price Float @default(0)
  buy_rate     Float
  total_value  Float
  bought_at    DateTime
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  client       Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@index([client_id])
  @@index([investment_type])
}

model HealthScore {
  id            String   @id @default(uuid())
  client_id     String
  score         Float    // 1-10
  breakdown     String?  // JSON breakdown of score components
  calculated_at DateTime @default(now())
  client        Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@index([client_id])
}

model HealthScoreFormula {
  id         String   @id @default(uuid())
  advisor_id String   @unique
  steps      Json
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  advisor    Advisor  @relation(fields: [advisor_id], references: [id], onDelete: Cascade)

  @@index([advisor_id])
}

model PortfolioTarget {
  id                 String   @id @default(uuid())
  client_id          String   @unique
  stock_target       Float    // 0-1 allocation target
  mutual_fund_target Float
  crypto_target      Float
  debt_target        Float
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  client             Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)
}

model MarketInsight {
  id               String   @id @default(uuid())
  title            String
  event_type       String
  severity         String
  ai_summary       String?
  affected_clients String[] // JSON array of client IDs or names
  created_at       DateTime @default(now())

  @@index([created_at])
}

model TodoItem {
  id          String   @id @default(uuid())
  advisor_id  String
  client_id   String?
  title       String
  description String?
  status      String   @default("pending") // pending | in_progress | done
  due_date    DateTime?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  advisor     Advisor  @relation(fields: [advisor_id], references: [id], onDelete: Cascade)
  client      Client?  @relation(fields: [client_id], references: [id], onDelete: SetNull)

  @@index([advisor_id])
  @@index([status])
}

/// Regulatory / filing deadlines for the advisor book (drives GET /compliance/upcoming).
model ComplianceObligation {
  id         String   @id @default(uuid())
  advisor_id String
  name       String
  due_date   DateTime
  status     String   @default("pending") // pending | urgent
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  advisor    Advisor  @relation(fields: [advisor_id], references: [id], onDelete: Cascade)

  @@index([advisor_id])
  @@index([due_date])
}

model PortfolioSnapshot {
  id          String   @id @default(uuid())
  client_id   String
  total_value Float
  date        DateTime @default(now())
  client      Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@index([client_id, date])
}
