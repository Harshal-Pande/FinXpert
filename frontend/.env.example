# Local dev: the app ignores relative NEXT_PUBLIC_API_URL and calls Nest directly (see lib/api/client.ts).
# Production (Vercel): set for **Production, Preview, and Development** so branch previews work.
#   NEXT_PUBLIC_API_URL=https://your-service.onrender.com/api
# Optional override when NEXT_PUBLIC_API_URL is unset (defaults to FinXpert Render in client.ts):
#   NEXT_PUBLIC_API_DEFAULT=https://your-service.onrender.com/api
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001/api
# Used in development for direct API calls (bypasses Next /api rewrites → no "Failed to proxy" on API restart).
BACKEND_ORIGIN=http://127.0.0.1:3001
# Next dev listens on 3020 by default (see frontend/package.json) so port 3001 stays free for the API.
